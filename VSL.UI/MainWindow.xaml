<ui:FluentWindow x:Class="VSL.UI.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:pages="clr-namespace:VSL.UI.Views.Pages"
                 mc:Ignorable="d"
                 Title="VintageStoryServerLauncher (VSL)"
                 Width="1360"
                 Height="860"
                 MinWidth="1120"
                 MinHeight="700"
                 Background="Transparent"
                 Icon="{DynamicResource VslAppLogoImage}"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 WindowCornerPreference="Round">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0"
                     Margin="14,0,0,8"
                     Background="{DynamicResource VslAppBackgroundBrush}"
                     ShowMinimize="True"
                     ShowMaximize="True"
                     ShowClose="True"
                     Title="Vintage Story Server Launcher">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="{DynamicResource VslAppLogoImage}" />
            </ui:TitleBar.Icon>
            <ui:TitleBar.Header>
                <Border Height="30" VerticalAlignment="Center" Background="Transparent">
                    <TextBlock Text="VSL 1.0" Opacity="0.7" VerticalAlignment="Center" />
                </Border>
            </ui:TitleBar.Header>
        </ui:TitleBar>

        <Grid Grid.Row="1" Margin="0,0,14,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="156" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    BorderThickness="0"
                    CornerRadius="0">
                <ui:NavigationView x:Name="RootNavigationView"
                                   Background="Transparent"
                                   PaneDisplayMode="Left"
                                   OpenPaneLength="156"
                                   CompactPaneLength="56"
                                   IsPaneVisible="True"
                                   IsPaneOpen="True"
                                   IsPaneToggleVisible="False"
                                   IsBackButtonVisible="Collapsed"
                                   IsFooterSeparatorVisible="True"
                                   Padding="8,8"
                                   SelectionChanged="RootNavigationView_OnSelectionChanged">
                    <ui:NavigationView.Resources>
                        <CornerRadius x:Key="ControlCornerRadius">8</CornerRadius>
                    </ui:NavigationView.Resources>
                    <ui:NavigationView.MenuItems>
                        <ui:NavigationViewItem x:Name="NavVersionProfiles" Content="版本与档案" Tag="versionprofile" IsActive="True" ToolTipService.ToolTip="版本与档案" Click="NavigationItem_OnClick">
                            <ui:NavigationViewItem.Icon>
                                <ui:SymbolIcon Style="{StaticResource VslNavSymbolIconStyle}" Symbol="BoxMultiple20" />
                            </ui:NavigationViewItem.Icon>
                        </ui:NavigationViewItem>
                        <ui:NavigationViewItem x:Name="NavSettings" Content="服务器配置" Tag="settings" ToolTipService.ToolTip="服务器配置" Click="NavigationItem_OnClick">
                            <ui:NavigationViewItem.Icon>
                                <ui:SymbolIcon Style="{StaticResource VslNavSymbolIconStyle}" Symbol="Server20" />
                            </ui:NavigationViewItem.Icon>
                        </ui:NavigationViewItem>
                        <ui:NavigationViewItem x:Name="NavAdvancedJson" Content="高级 JSON" Tag="advancedjson" ToolTipService.ToolTip="高级 JSON" Click="NavigationItem_OnClick">
                            <ui:NavigationViewItem.Icon>
                                <ui:SymbolIcon Style="{StaticResource VslNavSymbolIconStyle}" Symbol="CodeBlock20" />
                            </ui:NavigationViewItem.Icon>
                        </ui:NavigationViewItem>
                        <ui:NavigationViewItem x:Name="NavSaves" Content="存档管理" Tag="saves" ToolTipService.ToolTip="存档管理" Click="NavigationItem_OnClick">
                            <ui:NavigationViewItem.Icon>
                                <ui:SymbolIcon Style="{StaticResource VslNavSymbolIconStyle}" Symbol="Save20" />
                            </ui:NavigationViewItem.Icon>
                        </ui:NavigationViewItem>
                        <ui:NavigationViewItem x:Name="NavMapPreview" Content="地图预览" Tag="mappreview" ToolTipService.ToolTip="地图预览" Click="NavigationItem_OnClick">
                            <ui:NavigationViewItem.Icon>
                                <ui:SymbolIcon Style="{StaticResource VslNavSymbolIconStyle}" Symbol="Map20" />
                            </ui:NavigationViewItem.Icon>
                        </ui:NavigationViewItem>
                        <ui:NavigationViewItem x:Name="NavMods" Content="Mod 管理" Tag="mods" ToolTipService.ToolTip="Mod 管理" Click="NavigationItem_OnClick">
                            <ui:NavigationViewItem.Icon>
                                <ui:SymbolIcon Style="{StaticResource VslNavSymbolIconStyle}" Symbol="PuzzleCube20" />
                            </ui:NavigationViewItem.Icon>
                        </ui:NavigationViewItem>
                        <ui:NavigationViewItem x:Name="NavVs2QQConfig" Content="机器人配置" Tag="vs2qqconfig" ToolTipService.ToolTip="机器人配置" Click="NavigationItem_OnClick">
                            <ui:NavigationViewItem.Icon>
                                <ui:SymbolIcon Style="{StaticResource VslNavSymbolIconStyle}" Symbol="Bot20" />
                            </ui:NavigationViewItem.Icon>
                        </ui:NavigationViewItem>
                    </ui:NavigationView.MenuItems>

                    <ui:NavigationView.FooterMenuItems>
                        <ui:NavigationViewItem x:Name="NavConsole" Content="控制台" Tag="console" ToolTipService.ToolTip="控制台" Click="NavigationItem_OnClick">
                            <ui:NavigationViewItem.Icon>
                                <ui:SymbolIcon Style="{StaticResource VslNavSymbolIconStyle}" Symbol="WindowConsole20" />
                            </ui:NavigationViewItem.Icon>
                        </ui:NavigationViewItem>
                        <ui:NavigationViewItem x:Name="NavVs2QQRunner" Content="机器人" Tag="vs2qqrunner" ToolTipService.ToolTip="机器人" Click="NavigationItem_OnClick">
                            <ui:NavigationViewItem.Icon>
                                <ui:SymbolIcon Style="{StaticResource VslNavSymbolIconStyle}" Symbol="PlayCircle20" />
                            </ui:NavigationViewItem.Icon>
                        </ui:NavigationViewItem>
                        <ui:NavigationViewItem x:Name="NavAppSettings" Content="设置" Tag="appsettings" ToolTipService.ToolTip="设置" Click="NavigationItem_OnClick">
                            <ui:NavigationViewItem.Icon>
                                <ui:SymbolIcon Style="{StaticResource VslNavSymbolIconStyle}" Symbol="Settings20" />
                            </ui:NavigationViewItem.Icon>
                        </ui:NavigationViewItem>
                        <ui:NavigationViewItem x:Name="NavAbout" Content="关于" Tag="about" ToolTipService.ToolTip="关于" Click="NavigationItem_OnClick">
                            <ui:NavigationViewItem.Icon>
                                <ui:SymbolIcon Style="{StaticResource VslNavSymbolIconStyle}" Symbol="Info20" />
                            </ui:NavigationViewItem.Icon>
                        </ui:NavigationViewItem>
                    </ui:NavigationView.FooterMenuItems>
                </ui:NavigationView>
            </Border>

            <Border Grid.Column="2"
                    Style="{DynamicResource VslGlassPanelStyle}"
                    CornerRadius="8"
                    Margin="0,0,0,12"
                    Padding="12">
                <Grid>
                    <pages:VersionProfilesPage Visibility="{Binding SelectedNavKey, Converter={StaticResource NavKeyToVisibilityConverter}, ConverterParameter=versionprofile}" />
                    <pages:ServerSettingsPage Visibility="{Binding SelectedNavKey, Converter={StaticResource NavKeyToVisibilityConverter}, ConverterParameter=settings}" />
                    <pages:AdvancedJsonPage Visibility="{Binding SelectedNavKey, Converter={StaticResource NavKeyToVisibilityConverter}, ConverterParameter=advancedjson}" />
                    <pages:SavesPage Visibility="{Binding SelectedNavKey, Converter={StaticResource NavKeyToVisibilityConverter}, ConverterParameter=saves}" />
                    <pages:MapPreviewPage Visibility="{Binding SelectedNavKey, Converter={StaticResource NavKeyToVisibilityConverter}, ConverterParameter=mappreview}" />
                    <pages:ModsPage Visibility="{Binding SelectedNavKey, Converter={StaticResource NavKeyToVisibilityConverter}, ConverterParameter=mods}" />
                    <pages:Vs2QQConfigPage Visibility="{Binding SelectedNavKey, Converter={StaticResource NavKeyToVisibilityConverter}, ConverterParameter=vs2qqconfig}" />
                    <pages:ConsolePage Visibility="{Binding SelectedNavKey, Converter={StaticResource NavKeyToVisibilityConverter}, ConverterParameter=console}" />
                    <pages:Vs2QQRunnerPage Visibility="{Binding SelectedNavKey, Converter={StaticResource NavKeyToVisibilityConverter}, ConverterParameter=vs2qqrunner}" />
                    <pages:AppSettingsPage Visibility="{Binding SelectedNavKey, Converter={StaticResource NavKeyToVisibilityConverter}, ConverterParameter=appsettings}" />
                    <pages:AboutPage Visibility="{Binding SelectedNavKey, Converter={StaticResource NavKeyToVisibilityConverter}, ConverterParameter=about}" />
                </Grid>
            </Border>
        </Grid>

        <ui:SnackbarPresenter x:Name="RootSnackbarPresenter"
                              Grid.Row="1"
                              HorizontalAlignment="Right"
                              VerticalAlignment="Bottom"
                              Margin="0,0,24,18" />
    </Grid>
</ui:FluentWindow>
