<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">

    <!-- ===== 颜色定义 ===== -->
    <SolidColorBrush x:Key="VslAppBackgroundBrush" Color="#F5F0E6" />
    <SolidColorBrush x:Key="VslPanelBackgroundBrush" Color="#FFFDF8" />
    <SolidColorBrush x:Key="VslPanelBorderBrush" Color="#D4C4A8" />
    <SolidColorBrush x:Key="VslMutedTextBrush" Color="#8B7355" />
    <SolidColorBrush x:Key="VslPrimaryTextBrush" Color="#5D4E37" />
    <SolidColorBrush x:Key="VslAccentBrush" Color="#6B8E23" />
    <SolidColorBrush x:Key="VslAccentHoverBrush" Color="#556B2F" />
    <SolidColorBrush x:Key="VslLogoGreenBrush" Color="#6B8E23" />
    <SolidColorBrush x:Key="VslLogoBrownBrush" Color="#8B5A2B" />
    <SolidColorBrush x:Key="VslLogoGrayBrush" Color="#6B5B4F" />
    <SolidColorBrush x:Key="VslTableHeaderBrush" Color="#E8DFD0" />
    <SolidColorBrush x:Key="VslTableRowAlternateBrush" Color="#FAF7F0" />
    <SolidColorBrush x:Key="VslTableRowHoverBrush" Color="#EDE5D5" />
    <SolidColorBrush x:Key="VslTableRowSelectedBrush" Color="#D4E8A8" />
    <SolidColorBrush x:Key="VslActionBarBrush" Color="#F0EBE0" />
    <SolidColorBrush x:Key="VslCodePaneBrush" Color="#2D2416" />
    <SolidColorBrush x:Key="VslCodePaneTextBrush" Color="#D4C4A8" />
    <SolidColorBrush x:Key="VslHeaderBrush" Color="#FAFAFA" />
    <SolidColorBrush x:Key="LeftNavigationViewSeparatorBrush" Color="#D4C4A8" />
    <SolidColorBrush x:Key="NavigationViewContentGridBorderBrush" Color="#D4C4A8" />

    <!-- ===== 圆角定义 ===== -->
    <CornerRadius x:Key="ControlCornerRadius">3</CornerRadius>
    <CornerRadius x:Key="PopupCornerRadius">2</CornerRadius>

    <!-- ===== Logo 图片 ===== -->
    <DrawingImage x:Key="VslAppLogoImage">
        <DrawingImage.Drawing>
            <DrawingGroup>
                <GeometryDrawing Brush="{StaticResource VslLogoGreenBrush}" Geometry="M100,245 H300 A12,12 0 0 1 312,257 V421 A12,12 0 0 1 300,433 H100 A12,12 0 0 1 88,421 V257 A12,12 0 0 1 100,245 Z" />
                <GeometryDrawing Brush="{StaticResource VslLogoBrownBrush}" Geometry="M500,245 H700 A12,12 0 0 1 712,257 V421 A12,12 0 0 1 700,433 H500 A12,12 0 0 1 488,421 V257 A12,12 0 0 1 500,245 Z" />
                <GeometryDrawing Brush="{StaticResource VslLogoGrayBrush}" Geometry="M300,433 H500 A12,12 0 0 1 512,445 V621 A12,12 0 0 1 500,633 H300 A12,12 0 0 1 288,621 V445 A12,12 0 0 1 300,433 Z" />
            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>

    <!-- ===== 图标样式 ===== -->
    <Style x:Key="VslNavSymbolIconStyle" TargetType="ui:SymbolIcon">
        <Setter Property="Filled" Value="False" />
        <Setter Property="FontSize" Value="18" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="VslTitleBarSymbolIconStyle" TargetType="ui:SymbolIcon">
        <Setter Property="Filled" Value="False" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="Margin" Value="0,0,6,0" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="VslWindowControlSymbolIconStyle" TargetType="ui:SymbolIcon">
        <Setter Property="Filled" Value="False" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>

    <!-- ===== 面板样式 ===== -->
    <Style x:Key="VslGlassPanelStyle" TargetType="Border">
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="12" />
        <Setter Property="Background" Value="{StaticResource VslPanelBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource VslPanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <Style x:Key="VslActionBarHostStyle" TargetType="Border">
        <Setter Property="CornerRadius" Value="2" />
        <Setter Property="Padding" Value="8,6,4,2" />
        <Setter Property="Margin" Value="0,0,0,8" />
        <Setter Property="Background" Value="{StaticResource VslActionBarBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource VslPanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <!-- ===== 文字样式 ===== -->
    <Style x:Key="VslPageTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource VslPrimaryTextBrush}" />
    </Style>

    <Style x:Key="VslPageSubTitleStyle" TargetType="TextBlock">
        <Setter Property="Margin" Value="0,2,0,0" />
        <Setter Property="Foreground" Value="{StaticResource VslMutedTextBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="FontSize" Value="12" />
    </Style>

    <Style x:Key="VslEmptyHintStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{StaticResource VslMutedTextBrush}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="TextAlignment" Value="Center" />
        <Setter Property="Margin" Value="12" />
    </Style>

    <!-- ===== Card 样式 ===== -->
    <Style TargetType="ui:Card">
        <Setter Property="Margin" Value="0,0,0,12" />
        <Setter Property="Padding" Value="14" />
        <Setter Property="Background" Value="{StaticResource VslPanelBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource VslPanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <!-- ===== 按钮样式 ===== -->
    <Style x:Key="VslButtonBaseStyle" TargetType="Button">
        <Setter Property="BorderBrush" Value="#D4C4A8" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="10,4" />
        <Setter Property="Background" Value="#FAF7F0" />
        <Setter Property="Foreground" Value="#5D4E37" />
        <Setter Property="Height" Value="30" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="ButtonBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="2"
                            SnapsToDevicePixels="True">
                        <ContentPresenter Margin="{TemplateBinding Padding}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          RecognizesAccessKey="True" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ButtonBorder" Property="Background" Value="#EDE5D5" />
                            <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#6B8E23" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="ButtonBorder" Property="Background" Value="#D4C4A8" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="VslToolbarButtonStyle" TargetType="Button" BasedOn="{StaticResource VslButtonBaseStyle}">
        <Setter Property="Height" Value="32" />
        <Setter Property="MinWidth" Value="80" />
        <Setter Property="Margin" Value="0,0,8,8" />
        <Setter Property="Padding" Value="12,0" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <!-- ===== 控制台列表样式 ===== -->
    <Style x:Key="VslConsoleListBoxStyle" TargetType="ListBox">
        <Setter Property="Background" Value="{StaticResource VslCodePaneBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource VslPanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style x:Key="VslConsoleListBoxItemStyle" TargetType="ListBoxItem">
        <Setter Property="Padding" Value="6,2" />
        <Setter Property="Foreground" Value="#D4D4D4" />
    </Style>

    <!-- ===== 文本框样式 ===== -->
    <Style x:Key="VslTextBoxStyle" TargetType="TextBox">
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="Background" Value="#FFFFFF" />
        <Setter Property="Foreground" Value="#1A1A1A" />
        <Setter Property="BorderBrush" Value="#D0D0D0" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="10,0" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="TextBoxBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4"
                            SnapsToDevicePixels="True">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Margin="{TemplateBinding Padding}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="TextBoxBorder" Property="BorderBrush" Value="#7A9FD0" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="TextBoxBorder" Property="Opacity" Value="0.6" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="TextBox" BasedOn="{StaticResource VslTextBoxStyle}" />

    <!-- ===== 列表视图样式 ===== -->
    <Style x:Key="VslListViewStyle" TargetType="ListView">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Foreground" Value="#1A1A1A" />
        <Setter Property="AlternationCount" Value="1" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
        <Setter Property="ScrollViewer.CanContentScroll" Value="True" />
        <Setter Property="ClipToBounds" Value="False" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="Margin" Value="0,4,0,0" />
    </Style>

    <Style x:Key="VslGridViewHeaderStyle" TargetType="GridViewColumnHeader">
        <Setter Property="Height" Value="34" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Padding" Value="12,0" />
        <Setter Property="Background" Value="#70FFFFFF" />
        <Setter Property="Foreground" Value="#5A5A5A" />
        <Setter Property="BorderBrush" Value="#AADFE3E8" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="GridViewColumnHeader">
                    <Border x:Name="HeaderBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Margin="0,0,8,10"
                            CornerRadius="8"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          RecognizesAccessKey="True" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="VslListViewItemStyle" TargetType="ListViewItem">
        <Setter Property="MinHeight" Value="46" />
        <Setter Property="Padding" Value="8,8" />
        <Setter Property="Margin" Value="0,0,0,8" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="BorderBrush" Value="#CFE1E8" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Background" Value="#CCFFFFFF" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListViewItem">
                    <Border x:Name="RowBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="10"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <GridViewRowPresenter Columns="{Binding Path=View.Columns, RelativeSource={RelativeSource AncestorType=ListView}}"
                                              HorizontalAlignment="Stretch"
                                              VerticalAlignment="Center"
                                              Content="{TemplateBinding Content}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="RowBorder" Property="Background" Value="#F2F8FF" />
                            <Setter TargetName="RowBorder" Property="BorderBrush" Value="#AFCBEB" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="RowBorder" Property="Background" Value="#E6F0FF" />
                            <Setter TargetName="RowBorder" Property="BorderBrush" Value="#87ACDE" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="RowBorder" Property="Opacity" Value="0.6" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="VslTableCellTextStyle" TargetType="TextBlock">
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Margin" Value="12,2" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>

    <!-- ===== 全局字体设置 ===== -->
    <Style TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Microsoft YaHei UI, Segoe UI, SimHei, Arial, sans-serif" />
    </Style>

</ResourceDictionary>
